FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      netcat-openbsd \
      rsync && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY python_client /tmp/kubetorch/python_client
COPY examples/qwen3_asr_orin /tmp/kubetorch/examples/qwen3_asr_orin

RUN python -m pip install --upgrade pip && \
    python -m pip install -e /tmp/kubetorch/python_client[client] && \
    python -m pip install -e /tmp/kubetorch/examples/qwen3_asr_orin

CMD ["python", "-m", "kubetorch.run_wrapper", "--help"]
