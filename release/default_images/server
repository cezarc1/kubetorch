FROM python:3.11-slim

LABEL org.opencontainers.image.source="https://github.com/cezarc1/kubetorch"
LABEL org.opencontainers.image.description="Kubetorch Debian workload base image"
LABEL org.opencontainers.image.licenses="Apache-2.0"

# Install rsync and screen
RUN apt-get update && \
    apt-get install -y rsync screen coreutils && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

COPY release/default_images/requirements.txt ./requirements.txt
RUN pip install -r requirements.txt

WORKDIR /kt_app

EXPOSE 32300
